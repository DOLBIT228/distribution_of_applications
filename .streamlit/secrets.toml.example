[bitrix]
# Вхідний webhook Bitrix24 для роботи з CRM API (логін в CRM не потрібен)
# Формат: https://<your-domain>.bitrix24.ua/rest/<user_id>/<webhook_token>
webhook_url = "https://example.bitrix24.ua/rest/1/your_token"

[auth]
# Користувачі для входу саме в цей Streamlit-інтерфейс
# login/password + manager_id (ID менеджера в Bitrix)
[[auth.users]]
name = "Адміністратор"
login = "admin"
password = "admin123"
manager_id = 11

[[auth.users]]
name = "Керівник відділу"
login = "lead"
password = "lead123"
manager_id = 24

# Напрямки (воронка + статус для розподілу + статус після розподілу)
[[directions]]
name = "Сайт"
funnel_id = 0
status_id = "NEW"
next_status_id = "PREPARATION"

[[directions]]
name = "Instagram"
funnel_id = 2
status_id = "C2:NEW"
next_status_id = "C2:PREPARATION"

# Менеджери для розподілу (в UI відображається лише ім'я)
[[managers]]
name = "Іваненко Іван"
id = 11

[[managers]]
name = "Петренко Олена"
id = 24
